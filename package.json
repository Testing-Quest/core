{
  "name": "core",
  "private": true,
  "version": "0.0.0",
  "homepage": "https://testing-quest.github.io/",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
